<canvas id="shaders" transition:persist></canvas>

<style is:global>
  #shaders {
    position: absolute;
    z-index: -1;
    width: stretch;
    height: stretch;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    overflow: hidden;
    pointer-events: none;
    /* Fallback that matches the shader's void color, shown until WebGPU
       finishes compiling and draws the first frame. Eliminates the flash of
       the page background during the (sometimes slow) shader init. */
    background: #05030f;
  }
</style>

<script src="./shaders/nebula.ts"></script>
